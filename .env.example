# Required: Telegram Bot API token (get from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAH...

# Optional: Comma-separated Telegram user IDs to pre-approve (skip pairing)
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# Optional: Default working directory for new sessions (defaults to $HOME)
# ORCHESTRATOR_DEFAULT_CWD=/path/to/your/projects

# Optional: Max agentic turns per prompt (default: 50)
# ORCHESTRATOR_MAX_TURNS=50

# Optional: Default Claude model
# ORCHESTRATOR_MODEL=sonnet

# Optional: Absolute path to claude CLI binary (default: "claude" from $PATH)
# CLAUDE_BIN=/Users/you/.local/bin/claude
